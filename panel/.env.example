# DockPanel Panel Configuration
# Copy to .env and fill in values:  cp .env.example .env

# Database password (generate with: openssl rand -hex 24)
PANEL_DB_PASSWORD=change_me_to_random_string

# JWT signing secret (generate with: openssl rand -hex 32)
PANEL_JWT_SECRET=change_me_to_random_string

# Agent authentication token (must match /etc/dockpanel/agent.token)
AGENT_TOKEN=change_me_to_match_agent
